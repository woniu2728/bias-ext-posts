{
  "id": "posts",
  "name": "Posts",
  "version": "0.1.0",
  "description": "提供帖子 API、前端发帖入口和帖子生命周期界面；基础帖子数据由 content 提供。",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core",
    "users",
    "content"
  ],
  "optional_dependencies": [
    "discussions"
  ],
  "provides": [
    "posts",
    "post_lifecycle"
  ],
  "django": {
    "app_config": "bias_ext_posts.backend.apps.PostsExtensionConfig",
    "app_label": "posts",
    "migration_module": "bias_ext_posts.backend.django_migrations"
  },
  "backend": {
    "entry": "bias_ext_posts.backend.ext"
  },
  "frontend": {
    "admin_entry": "frontend/admin/index.js",
    "forum_entry": "frontend/forum/index.js"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true
  },
  "security": {
    "capabilities_notice": "Post UI/API wrapper; delegates post records to the content foundation and contributes composer runtime, lifecycle, and moderation surfaces."
  }
}
